# ── Line endings: normalize everything to LF in the repo ──────
*                text=auto eol=lf

# ── Git LFS — large model weight files ────────────────────────
*.pth            filter=lfs diff=lfs merge=lfs -text
*.keras          filter=lfs diff=lfs merge=lfs -text

# ── Binary files — no diff/merge/eol conversion ───────────────
*.png            binary
*.jpg            binary
*.jpeg           binary
*.gif            binary
*.ico            binary
*.webp           binary
*.pth            binary
