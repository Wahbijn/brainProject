# ── Large model weights – tracked via Git LFS ────────────────
# Run: git lfs install && git lfs track "*.pth"
# The .gitattributes file already handles this.
# If you are NOT using Git LFS, uncomment the lines below
# to exclude the large classification model (90 MB):
# BrainTumor/ClassificationModel/best_model.pth

