# ══════════════════════════════════════════════════════════════
#  Neural Medical AI — Environment Variables Template
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  Variables prefixed with NEXT_PUBLIC_ are exposed to the
#  browser. All others are server-side only.
# ══════════════════════════════════════════════════════════════

# ── Brain Tumor AI Server ─────────────────────────────────────
# URL of the Python Flask inference server (BrainTumor/brain_api.py)
# Local development default:
BRAIN_API_URL=http://localhost:5001
# Production example (if you deploy the Python server):
# BRAIN_API_URL=https://your-ai-server.com

# ── Application ───────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Neural Medical AI
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# ── Python AI Server port ─────────────────────────────────────
# Port that brain_api.py listens on. Must match BRAIN_API_URL.
BRAIN_API_PORT=5001
